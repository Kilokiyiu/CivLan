<Window x:Class="CivLan.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CivLan - 文明6联机"
        Height="820"
        Width="920"
        MinHeight="720"
        MinWidth="800"
        Background="#F3F4F6">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="CivLan"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#111827" />
                <TextBlock Text="文明6虚拟局域网联机助手（内置 WireGuard）"
                           FontSize="14"
                           Foreground="#6B7280"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="服务器地址" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="ServerUrlTextBox" Text="http://YOUR_SERVER_IP:5199" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox x:Name="ApiKeyTextBox" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="测试连接"
                            VerticalAlignment="Bottom"
                            Padding="16,8"
                            Click="TestConnectionButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="创建房间" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                        <TextBlock Text="房间名称" Margin="0,0,0,6" />
                        <TextBox x:Name="CreateRoomNameTextBox" Text="周末文明局" Margin="0,0,0,12" />
                        <TextBlock Text="你的昵称" Margin="0,0,0,6" />
                        <TextBox x:Name="CreatePlayerNameTextBox" Margin="0,0,0,16" />
                        <Button Content="创建房间"
                                Padding="14,12"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CreateRoomButton_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="加入房间" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                        <TextBlock Text="房间码 (6位)" Margin="0,0,0,6" />
                        <TextBox x:Name="JoinRoomCodeTextBox" CharacterCasing="Upper" MaxLength="6" Margin="0,0,0,12" />
                        <TextBlock Text="你的昵称" Margin="0,0,0,6" />
                        <TextBox x:Name="JoinPlayerNameTextBox" Margin="0,0,0,16" />
                        <Button Content="加入房间"
                                Padding="14,12"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="#059669"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="JoinRoomButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="联机信息"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="VPN 状态：" FontWeight="SemiBold" />
                        <TextBlock x:Name="VpnStatusTextBlock" Text="未连接" Margin="4,0,16,0" Foreground="#DC2626" FontWeight="Bold" />
                        <TextBlock Text="房间码：" FontWeight="SemiBold" />
                        <TextBlock x:Name="RoomCodeTextBlock" Text="-" Margin="4,0,16,0" FontWeight="Bold" />
                        <TextBlock Text="你的虚拟 IP：" FontWeight="SemiBold" />
                        <TextBlock x:Name="VirtualIpTextBlock" Text="-" Margin="4,0,16,0" />
                        <TextBlock Text="主机 IP：" FontWeight="SemiBold" />
                        <TextBlock x:Name="HostIpTextBlock" Text="-" Margin="4,0,0,0" Foreground="#B45309" FontWeight="Bold" />
                    </StackPanel>

                    <TextBlock x:Name="StatusMessageTextBlock"
                               Text=""
                               Foreground="#6B7280"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap" />

                    <TextBlock Text="WireGuard 配置"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="WireGuardConfigTextBox"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Height="100"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="ConnectVpnButton"
                                Content="连接 VPN"
                                Padding="14,10"
                                FontWeight="SemiBold"
                                Background="#7C3AED"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0,0,8,0"
                                Click="ConnectVpnButton_Click" />
                        <Button x:Name="DisconnectVpnButton"
                                Content="断开 VPN"
                                Padding="14,10"
                                Margin="0,0,8,0"
                                Click="DisconnectVpnButton_Click" />
                        <Button Content="手动选择安装包"
                                Padding="12,10"
                                Margin="0,0,8,0"
                                Click="ManualInstallButton_Click" />
                        <Button Content="复制主机 IP"
                                Padding="12,10"
                                Margin="0,0,8,0"
                                Click="CopyHostIpButton_Click" />
                        <Button Content="刷新房间"
                                Padding="12,10"
                                Click="RefreshRoomButton_Click" />
                    </StackPanel>

                    <TextBlock Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"
                               Text="WireGuard 组件可内置在软件 wireguard 文件夹中，无需联网下载。首次连接仅需安装驱动（管理员权限，仅一次）。" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
